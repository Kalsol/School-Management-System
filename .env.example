APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=sms
# DB_USERNAME=
# DB_PASSWORD=

# BROADCAST_DRIVER=log
CACHE_DRIVER=file
# QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=yourport
MAIL_ENCRYPTION=MAIL_ENCRYPTIONtype
MAIL_USERNAME=your_email
MAIL_PASSWORD=yourpassword
# MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="your-email@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_TO="your@gmail.com"

AFRO_MESSAGE_URL = https://api.afromessage.com/api/send
AFRO_MESSAGE_SENDER = ""
AFRO_MESSAGE_FROM = ""
AFRO_MESSAGE_CALLBACK = ""
AFRO_MESSAGE_TOKEN = "Your Afro message token"

BROADCAST_DRIVER=pusher
PUSHER_APP_ID=''
PUSHER_APP_KEY=''
PUSHER_APP_SECRET=''
PUSHER_APP_CLUSTER=''
PUSHER_SCHEME=http
PUSHER_PORT=80
PUSHER_USE_TLS=false

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
